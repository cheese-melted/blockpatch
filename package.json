{
  "name": "blockpatch",
  "version": "1.1.1",
  "description": "Hash-verified, reviewable block-move patches for coding agents",
  "packageManager": "bun@1.3.14",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cheese-melted/blockpatch.git"
  },
  "bugs": {
    "url": "https://github.com/cheese-melted/blockpatch/issues"
  },
  "homepage": "https://github.com/cheese-melted/blockpatch#readme",
  "keywords": [
    "patch",
    "diff",
    "refactor",
    "codemod",
    "text",
    "agent",
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "./dist/pi/index.js"
    ]
  },
  "bin": {
    "blockpatch": "dist/cli.js",
    "blockpatch-conformance": "conformance/runner.mjs"
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "integrations",
    "conformance",
    "README.md",
    "CONTRIBUTING.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "experiment": "node experiment/harness.mjs",
    "build": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\" && bun build ./src/cli.ts --target=node --outdir=dist && bun build ./integrations/pi/index.ts --target=node --outdir=dist/pi --external @earendil-works/pi-coding-agent --external typebox",
    "smoke:dist": "node test/built-cli-smoke.mjs",
    "smoke:pack": "node test/packed-cli-smoke.mjs",
    "conformance": "node conformance/runner.mjs node dist/cli.js",
    "prepublishOnly": "bun run typecheck && bun test && bun run build && npm run smoke:dist && npm run smoke:pack",
    "pack:dry": "npm pack --dry-run",
    "publish:dry": "npm publish --dry-run"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.4",
    "@types/bun": "^1.3.14",
    "@types/node": "^20",
    "typebox": "^1.1.38",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  }
}
